{% include date_badge_styles.liquid %}
<div class="news">
  {% assign presentation_items = site.work | where: 'category', 'presentations' %}
  {% if presentation_items != blank %}
    {% assign presentation_size = presentation_items | size %}
    <div
      class="publications"
      {% if include.limit and page.announcements.scrollable and presentation_size > 3 %}
        style="max-height: 60vw; overflow-y: auto"
      {% endif %}
    >
      {% if include.limit and page.announcements.limit %}
        {% assign news_limit = page.announcements.limit %}
      {% else %}
        {% assign news_limit = presentation_size %}
      {% endif %}
      {% include presentations_and_posters.liquid limit=news_limit %}
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
