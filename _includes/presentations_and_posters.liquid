{% assign presentation_items = site.work | where: 'category', 'presentations' | sort: 'date' | reverse %}
{% if include.limit %}
  {% assign presentation_limit = include.limit %}
{% else %}
  {% assign presentation_limit = presentation_items.size %}
{% endif %}

<ol class="bibliography">
  {% for item in presentation_items limit: presentation_limit %}
    <li>
      <div class="row">
        <div class="col col-sm-2 abbr">
          <abbr class="badge rounded w-100">{{ item.date | date: '%b %Y' }}</abbr>
        </div>
        <div class="col-sm-10">
          {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
        </div>
      </div>
    </li>
  {% endfor %}
</ol>
